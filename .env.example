# Character Consistency Lab - Environment Variables

# fal.ai API Key (for FLUX.2 Generation)
# Get yours at: https://fal.ai/dashboard/keys
FAL_KEY=your_fal_key_here

# Google API Key (for Gemini 1.5 Pro Vision Scorer & Nano Banana)
# Get yours at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# Project Configuration
MODEL_ID=flux2 # Default model
MAX_IMAGE_BUDGET=10 # Safety catch: maximum generations per session
DEBUG=true
